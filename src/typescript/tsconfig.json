{
  "compilerOptions": {
    "target": "es2022",                          /* Set the JavaScript language version for emitted JavaScript */
    "module": "es2022", 
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node","jest"],
    "typeRoots": ["../../packages/grpc-web/node_modules/@types"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "paths": {
        // Points directly to the file to avoid folder resolution issues
        "@closure-net/blob": [
          "../../packages/closure-wrapper/node_modules/closure-net/grpc_web/grpc_web_blob_types.d.ts"
        ]
      }
  },
  "exclude": [
    "node_modules"
  ]
}
