{
  "compilerOptions": {
    "target": "es2022",                          /* Set the JavaScript language version for emitted JavaScript */
    "module": "commonjs", 
    "strict": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": false,
    "types": ["node","jasmine"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "paths": {
        // Points directly to the file to avoid folder resolution issues
        "@closure-net/blob": [
          "../../packages/closure-wrapper/dist/grpc_web_blob_types.d.ts"
        ]
      }
  },
  "exclude": [
    "node_modules"
  ]
}
